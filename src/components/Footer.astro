---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-zinc-800 bg-zinc-950">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <div>
        <span class="text-lg font-bold text-gradient">CyberInventors</span>
        <p class="mt-2 text-sm text-zinc-400">
          Tracking the startups building the future of cybersecurity.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-zinc-300">Explore</h3>
        <ul class="mt-3 space-y-2">
          {
            [
              { href: "/directory", label: "Company Directory" },
              { href: "/news", label: "News Feed" },
              { href: "/about", label: "About" },
              { href: "/submit", label: "Submit a Company" },
            ].map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-zinc-400 transition-colors hover:text-white"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-zinc-300">Stay Updated</h3>
        <p class="mt-3 text-sm text-zinc-400">
          Cybersecurity startup news delivered to your inbox.
        </p>
        <!-- Newsletter signup placeholder -->
        <form class="mt-3 flex gap-2">
          <input
            type="email"
            placeholder="your@email.com"
            class="w-full rounded-lg border border-zinc-700 bg-zinc-800 px-3 py-2 text-sm text-white placeholder-zinc-500 focus:border-brand-500 focus:outline-none"
          />
          <button
            type="submit"
            class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-brand-500"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <div class="mt-8 border-t border-zinc-800 pt-8 text-center">
      <p class="text-xs text-zinc-500">
        &copy; {currentYear} CyberInventors. Built with Astro & Cloudflare.
      </p>
    </div>
  </div>
</footer>
