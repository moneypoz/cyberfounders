---
import Base from "@/layouts/Base.astro";
import CompanyCard from "@/components/CompanyCard.astro";
import { getCollection } from "astro:content";

const allCompanies = await getCollection("companies");
const companies = allCompanies.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

// Gather all unique categories for filter UI
const allCategories = [
  ...new Set(companies.flatMap((c) => c.data.category)),
].sort();
---

<Base title="Company Directory" description="Browse all cybersecurity startups in the CyberInventors directory.">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-10">
      <h1 class="text-4xl font-extrabold text-white">Company Directory</h1>
      <p class="mt-2 text-zinc-400">
        {companies.length} companies tracked across the cybersecurity landscape.
      </p>
    </div>

    <!-- Category filters (static for now; enhance with client-side JS later) -->
    <div class="mb-8 flex flex-wrap gap-2">
      <span class="rounded-full bg-brand-600 px-3 py-1 text-xs font-medium text-white">
        All
      </span>
      {
        allCategories.map((cat) => (
          <span class="cursor-pointer rounded-full border border-zinc-700 px-3 py-1 text-xs font-medium text-zinc-400 transition-colors hover:border-zinc-500 hover:text-white">
            {cat}
          </span>
        ))
      }
    </div>

    {
      companies.length > 0 ? (
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {companies.map((company) => (
            <CompanyCard
              name={company.data.name}
              slug={company.id.replace(/\.(md|mdx)$/, "")}
              tagline={company.data.tagline}
              category={company.data.category}
              stage={company.data.stage}
              location={company.data.location}
              featured={company.data.featured}
            />
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-dashed border-zinc-700 py-24 text-center">
          <p class="text-zinc-500">No companies in the directory yet.</p>
          <a
            href="/submit"
            class="mt-4 inline-block text-sm text-brand-400 hover:text-brand-300"
          >
            Be the first to submit one →
          </a>
        </div>
      )
    }
  </div>
</Base>
