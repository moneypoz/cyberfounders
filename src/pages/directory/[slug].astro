---
import Base from "@/layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const companies = await getCollection("companies");
  return companies.map((company) => ({
    params: { slug: company.id.replace(/\.(md|mdx)$/, "") },
    props: { company },
  }));
}

const { company } = Astro.props;
const { Content } = await render(company);
const { name, tagline, description, website, founded, location, stage, category } = company.data;
---

<Base title={name} description={description}>
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Back link -->
    <a
      href="/directory"
      class="mb-8 inline-flex items-center gap-1 text-sm text-zinc-400 transition-colors hover:text-white"
    >
      ← Back to Directory
    </a>

    <header class="mb-10 flex items-start gap-6">
      <!-- Logo placeholder -->
      <div
        class="flex size-16 shrink-0 items-center justify-center rounded-xl bg-zinc-800 text-2xl font-bold text-zinc-400"
      >
        {name.charAt(0)}
      </div>
      <div>
        <h1 class="text-3xl font-extrabold text-white">{name}</h1>
        <p class="mt-1 text-lg text-zinc-400">{tagline}</p>
        <div class="mt-3 flex flex-wrap gap-2">
          {
            category.map((cat) => (
              <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-xs text-zinc-400">
                {cat}
              </span>
            ))
          }
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 gap-10 lg:grid-cols-3">
      <!-- Main content -->
      <article class="lg:col-span-2 prose prose-invert prose-zinc max-w-none">
        <Content />
      </article>

      <!-- Sidebar -->
      <aside class="space-y-4">
        <div class="card">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-zinc-400">
            Company Info
          </h2>
          <dl class="space-y-3 text-sm">
            {
              website && (
                <div>
                  <dt class="text-zinc-500">Website</dt>
                  <dd>
                    <a
                      href={website}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-brand-400 hover:text-brand-300 break-all"
                    >
                      {website.replace(/^https?:\/\//, "")}
                    </a>
                  </dd>
                </div>
              )
            }
            {
              location && (
                <div>
                  <dt class="text-zinc-500">Location</dt>
                  <dd class="text-zinc-200">{location}</dd>
                </div>
              )
            }
            {
              founded && (
                <div>
                  <dt class="text-zinc-500">Founded</dt>
                  <dd class="text-zinc-200">{founded}</dd>
                </div>
              )
            }
            {
              stage && (
                <div>
                  <dt class="text-zinc-500">Stage</dt>
                  <dd class="capitalize text-zinc-200">{stage}</dd>
                </div>
              )
            }
          </dl>
        </div>
      </aside>
    </div>
  </div>
</Base>
