---
import Base from "@/layouts/Base.astro";
import NewsReel from "@/components/NewsReel.astro";
import { getCollection } from "astro:content";
import { filterNewsForDirectory, type NewsItem } from "@/lib/filterNews";

const allCompanies = await getCollection("companies");
const companyNames = allCompanies.map((c) => c.data.name);
const founderNames = allCompanies.flatMap((c) => c.data.founders ?? []);

const NEWS_API_URL = import.meta.env.NEWS_API_URL;

let newsItems: NewsItem[] = [];
let fetchError: string | null = null;

if (NEWS_API_URL) {
  try {
    const res = await fetch(`${NEWS_API_URL}/news.json`);
    if (res.ok) {
      const all: NewsItem[] = await res.json();
      newsItems = filterNewsForDirectory(all, companyNames, founderNames);
    } else {
      fetchError = `Worker responded ${res.status}`;
    }
  } catch (e) {
    fetchError = e instanceof Error ? e.message : "Unknown fetch error";
  }
} else {
  fetchError = "NEWS_API_URL is not set";
}
---

<Base title="News" description="Latest news about women founders and companies in the CyberInventors directory.">
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-10">
      <h1 class="text-4xl font-extrabold text-white">Founder News</h1>
      <p class="mt-2 text-zinc-400">
        Coverage of the founders and companies in this directory, aggregated automatically.
      </p>
    </div>

    {
      fetchError ? (
        <div class="rounded-xl border border-dashed border-zinc-700 py-24 text-center">
          <p class="text-zinc-500">News feed unavailable at build time.</p>
          <p class="mt-2 text-xs text-zinc-600">{fetchError}</p>
        </div>
      ) : newsItems.length > 0 ? (
        <NewsReel items={newsItems} limit={50} />
      ) : (
        <div class="rounded-xl border border-dashed border-zinc-700 py-24 text-center">
          <p class="text-zinc-500">No recent coverage found for these founders.</p>
          <p class="mt-2 text-xs text-zinc-600">
            The feed refreshes hourly — check back soon, or
            <a href="/submit" class="text-brand-400 hover:text-brand-300"> add more founders</a>.
          </p>
        </div>
      )
    }
  </div>
</Base>
