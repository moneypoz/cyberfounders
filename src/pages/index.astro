---
import Base from "@/layouts/Base.astro";
import FounderCard from "@/components/FounderCard.astro";
import NewsReel from "@/components/NewsReel.astro";
import { getCollection } from "astro:content";
import { filterNewsForDirectory, type NewsItem } from "@/lib/filterNews";

const allCompanies = await getCollection("companies");
const featuredCompanies = allCompanies
  .filter((c) => c.data.featured)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const companyNames = allCompanies.map((c) => c.data.name);
const founderNames = allCompanies.flatMap((c) => c.data.founders ?? []);

let newsItems: NewsItem[] = [];
const NEWS_API_URL = import.meta.env.NEWS_API_URL;
if (NEWS_API_URL) {
  try {
    const res = await fetch(`${NEWS_API_URL}/news.json`);
    if (res.ok) {
      const all: NewsItem[] = await res.json();
      newsItems = filterNewsForDirectory(all, companyNames, founderNames);
    }
  } catch {
    // silently degrade — sidebar shows empty state
  }
}
---

<Base
  title="Home"
  description="A curated directory of women founders and leaders in cybersecurity — their companies, their work, their news."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-zinc-800 bg-zinc-950 py-24">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-900/20 via-transparent to-transparent" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-5xl font-extrabold leading-tight tracking-tight">
          Meet the women<br />
          <span class="text-gradient">building the future</span><br />
          of cybersecurity.
        </h1>
        <p class="mt-6 text-lg text-zinc-400">
          A curated directory of women founders and leaders in cyber — their
          companies, their work, their news.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/founders"
            class="rounded-lg bg-brand-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-brand-500"
          >
            Meet the Founders
          </a>
          <a
            href="/submit"
            class="rounded-lg border border-zinc-700 px-6 py-3 font-semibold text-zinc-300 transition-colors hover:border-zinc-500 hover:text-white"
          >
            Submit Your Company
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-3">
      <!-- Featured Founders -->
      <section class="lg:col-span-2">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-xl font-bold text-white">Featured Founders</h2>
          <a href="/founders" class="text-sm text-brand-400 hover:text-brand-300">
            View all →
          </a>
        </div>
        {
          featuredCompanies.length > 0 ? (
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              {featuredCompanies.slice(0, 4).map((company) => (
                <FounderCard
                  founderName={company.data.founders?.[0] ?? company.data.name}
                  companyName={company.data.name}
                  slug={company.id.replace(/\.(md|mdx)$/, "")}
                  tagline={company.data.tagline}
                  category={company.data.category}
                  stage={company.data.stage}
                  location={company.data.location}
                  featured={company.data.featured}
                  photo={company.data.photo}
                />
              ))}
            </div>
          ) : (
            <p class="text-zinc-500">No featured founders yet.</p>
          )
        }
      </section>

      <!-- News Sidebar -->
      <section>
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-xl font-bold text-white">Latest News</h2>
          <a href="/news" class="text-sm text-brand-400 hover:text-brand-300">
            More →
          </a>
        </div>
        <NewsReel items={newsItems} limit={8} />
      </section>
    </div>
  </div>
</Base>
